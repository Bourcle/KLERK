APP_ENV=dev
LOG_LEVEL=INFO

# Local vLLM OpenAI-compatible server. Change only the model name for your setup.
LOCAL_LLM_PROVIDER=vllm
LOCAL_LLM_BASE_URL=http://localhost:8000/v1
LOCAL_LLM_MODEL=your-local-vllm-model
LOCAL_LLM_API_KEY=dummy
LOCAL_LLM_TEMPERATURE=0.1
LOCAL_LLM_MAX_TOKENS=2048

# Keep local bge-m3 embeddings for Chroma build/search.
LOCAL_EMBEDDING_PROVIDER=local
LOCAL_EMBEDDING_MODEL=BAAI/bge-m3
LOCAL_EMBEDDING_BASE_URL=

CHECKPOINT_SQLITE_PATH=.data/checkpoints.sqlite
MEMORY_SQLITE_PATH=.data/memory.sqlite
CHROMA_PERSIST_DIR=.data/chroma

DEFAULT_COLLECTION=korean_law
USE_TOPIC_COLLECTIONS=true
VECTOR_TOP_K=4
MCP_FETCH_TOP_N=3
SIMILARITY_THRESHOLD=0.40
MIN_RETRIEVED_DOCS=2
MAX_CONTEXT_CHARS=5000
MAX_RETRIEVAL_ITERATIONS=3
RERANK_TOP_K=4

MEMORY_HALF_LIFE_DAYS=30
MEMORY_DEFAULT_IMPORTANCE=0.55
MEMORY_TOP_K=3

GRADIO_HOST=127.0.0.1
GRADIO_PORT=7860
CHAR_STREAM_DELAY=0.01

# Optional Korean Law MCP server.
LAW_API_OC=
MCP_SERVER_COMMAND=node
MCP_SERVER_ENTRYPOINT=./external/korean-law-mcp/dist/index.js
